rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Helper: check if user is the owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 1. Static/Public Collections (Read: Anyone, Write: Admin)
    match /airports/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /popular_destinations/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /offers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /aircrafts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pricing_rules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /routes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Flight Management (Read: Anyone, Write: Admin)
    match /flights/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /flight_status/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null; 
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 4. Bookings (Public Create for Guests, Owner Read/Write)
    match /bookings/{id} {
      allow create: if true; // Allow guest booking
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid) || (resource.data.userId == 'guest'); 
      allow update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid) || (resource.data.userId == 'guest');
      allow delete: if isAdmin();
    }

    // 5. Seats (Read: Anyone, Write: Anyone for booking, Admin)
    match /seats/{id} {
      allow read: if true;
      allow write: if true; // Simple for now to allow seat selection
    }

    // 6. Payments & Invoices (Admin Read, Public Create)
    match /payments/{id} {
      allow read: if isAdmin();
      allow create: if true;
    }
    match /invoices/{id} {
      allow read: if isAdmin();
      allow create: if true;
    }

    // 7. Loyalty System (Public Read/Create during signup, Admin Management)
    match /loyalty_accounts/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /points_transactions/{id} {
      allow read: if true;
      allow write: if true;
    }

    // 8. Notifications & Logs
    match /notifications/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow write: if true;
    }
    match /login_attempts/{id} {
      allow read, write: if isAdmin();
    }
    
    match /tickets/{id} {
      allow read: if true;
      allow write: if true;
    }

    // Default Deny for safety
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
